# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as long as we don't check in the exe itself
#  we can ignore these.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

